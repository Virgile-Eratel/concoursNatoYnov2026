;NANO e TTC
%USB\VID_0403&PID_B2E6.DeviceDesc%=FtdiBus.NT,USB\VID_0403&PID_B2E6
%USB\VID_0403&PID_B2E7.DeviceDesc%=FtdiBus.NT,USB\VID_0403&PID_B2E7
;Axone PAD dual core e Tester Pressioni
%USB\VID_0403&PID_8AF0.DeviceDesc%=FtdiBus.NT,USB\VID_0403&PID_8AF0
%USB\VID_0403&PID_8AF1.DeviceDesc%=FtdiBus.NT,USB\VID_0403&PID_8AF1
;Adpter TMD starter
%USB\VID_0403&PID_8AF2.DeviceDesc%=FtdiBus.NT,USB\VID_0403&PID_8AF2
