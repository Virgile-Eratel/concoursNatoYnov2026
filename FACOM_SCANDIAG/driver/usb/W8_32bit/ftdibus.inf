[FtdiHw.NTamd64]
%USB\VID_0403&PID_DD00.DeviceDesc%=FtdiBus.NTamd64,USB\VID_0403&PID_DD00
%USB\VID_0403&PID_DD01.DeviceDesc%=FtdiBus.NTamd64,USB\VID_0403&PID_DD01
